---
config:
  theme: default
  flowchart:
    curve: linear
---
flowchart TD

    %% Основная вертикальная цепочка
    P[Пароль P] --> PRF[PRF = HMAC]
    PRF --> U1["$$U_1 = PRF(P, S || i)$$"]
    U1 --> Uj["$$U_j = PRF(P, U_{j-1})$$"]
    Uj --> F["$$F(P,S,c,i) = U_1 \oplus U_2 \oplus ... \oplus U_c$$"]
    F --> DK["$$DK = PBKDF2(P,S,c,dkLen)$$"]

    %% Боковые входы
    S[Соль S] --> U1
    C[Число итераций c] --> F