[project]
site_name = "[[ project_name ]]"
site_author = "ethercod3"
docs_dir = "docs/ru"
site_dir = "docs-site"
dev_addr = "0.0.0.0:8000"
repo_url = "https://github.com/ethercod3/latex_thesis_template"
repo_name = "ethercod3/latex_thesis_template"
copyright = "Copyright &copy; <a href=\"https://github.com/ethercod3\">ethercod3</a>"
nav = [
  {"Начало" = "README.md"},
  {"Быстрый старт" = "quick-start.md"},
  {"Структура проекта" = "project-structure.md"},
  {"Сборка" = "build.md"},
[[% if include_pdf_tools %]]
  {"PDF-инструменты" = "pdf-tools.md"},
[[% endif %]]
[[% if include_docx_tools %]]
  {"Титульные страницы" = "title-pages.md"},
[[% endif %]]
[[% if include_diagram_tools %]]
  {"Диаграммы" = "diagrams.md"},
[[% endif %]]
[[% if include_backup_tools %]]
  {"Резервное копирование" = "backup.md"},
[[% endif %]]
[[% if include_ci %]]
  {"CI/CD" = "ci.md"},
[[% endif %]]
]

[project.theme]
language = "ru"
features = ["content.code.copy", "navigation.top", "search.highlight"]
palette = [
  {media = "(prefers-color-scheme: light)", scheme = "default", toggle = {icon = "material/weather-night", name = "Переключить на темную тему"}},
  {media = "(prefers-color-scheme: dark)", scheme = "slate", toggle = {icon = "material/weather-sunny", name = "Переключить на светлую тему"}},
]

[project.extra]
alternate = [
  {name = "Русский", link = "/", lang = "ru"},
  {name = "English", link = "/en/", lang = "en"},
]
