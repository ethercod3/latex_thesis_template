root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.py]
indent_size = 4
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.json]
indent_size = 4

[*.{md,tex,bib}]
indent_size = 2
trim_trailing_whitespace = false

[*.{bat,cmd,ps1}]
end_of_line = crlf

[Makefile]
indent_style = tab

[*.lock]
insert_final_newline = true
trim_trailing_whitespace = false
