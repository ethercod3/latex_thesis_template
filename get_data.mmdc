flowchart TD
    A([Начало])

    subgraph S1[Получение записи]
        B[Поиск записи в data_records по имени]
    end

    subgraph S2[Авторизация]
        C[Проверка Authorization Bearer против auth_hash]
    end

    subgraph S3[Работа с ключом и контейнером]
        D[Получение dek_out]
        E[Unwrap ключа]
        F[Валидация заголовка контейнера]
    end

    subgraph S4[Выдача данных]
        G[Расшифрование payload_hex]
        H[Возврат plaintext в API-ответе]
    end

    I([Завершение])

    A --> B --> C --> D --> E --> F --> G --> H --> I