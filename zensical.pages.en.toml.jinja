[project]
site_name = "[[ project_name ]]"
site_author = "ethercod3"
docs_dir = "docs/en"
site_dir = "docs-site/en"
site_url = "https://ethercod3.github.io/latex_thesis_template/en/"
repo_url = "https://github.com/ethercod3/latex_thesis_template"
repo_name = "ethercod3/latex_thesis_template"
copyright = "Copyright &copy; <a href=\"https://github.com/ethercod3\">ethercod3</a>"
nav = [
  {"Start" = "README.md"},
  {"Quick Start" = "quick-start.md"},
  {"Project Structure" = "project-structure.md"},
  {"Build" = "build.md"},
[[% if include_pdf_tools %]]
  {"PDF Tools" = "pdf-tools.md"},
[[% endif %]]
[[% if include_docx_tools %]]
  {"Title Pages" = "title-pages.md"},
[[% endif %]]
[[% if include_diagram_tools %]]
  {"Diagrams" = "diagrams.md"},
[[% endif %]]
[[% if include_backup_tools %]]
  {"Backup" = "backup.md"},
[[% endif %]]
[[% if include_ci %]]
  {"CI/CD" = "ci.md"},
[[% endif %]]
]

[project.theme]
language = "en"
features = ["content.code.copy", "navigation.top", "search.highlight"]
palette = [
  {media = "(prefers-color-scheme: light)", scheme = "default", toggle = {icon = "material/weather-night", name = "Switch to dark theme"}},
  {media = "(prefers-color-scheme: dark)", scheme = "slate", toggle = {icon = "material/weather-sunny", name = "Switch to light theme"}},
]

[project.extra]
alternate = [
  {name = "Русский", link = "https://ethercod3.github.io/latex_thesis_template/", lang = "ru"},
  {name = "English", link = "https://ethercod3.github.io/latex_thesis_template/en/", lang = "en"},
]
